<style>
    .font-charm {
        font-family: "Charm", cursive;
    }

    .evento-item p {
        transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    }
    .evento-item:hover p:first-of-type {
        color: #c9a96e;
        transform: scale(1.08);
        text-shadow: 0 2px 8px rgba(156, 122, 46, 0.3);
    }

    .corazon-item {
        filter: drop-shadow(0 4px 12px rgba(156, 122, 46, 0.5));
        transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    }
    .corazon-item:hover {
        transform: scale(1.2) rotate(10deg);
        filter: drop-shadow(0 8px 20px rgba(156, 122, 46, 0.7));
    }

    .dorado-filter {
        filter: brightness(0) saturate(100%) invert(56%) sepia(77%)
            saturate(419%) hue-rotate(5deg) brightness(94%) contrast(92%)
            drop-shadow(0 4px 10px rgba(156, 122, 46, 0.2));
        transition:
            filter 0.3s ease,
            transform 0.3s ease;
    }
    .evento-item img.dorado-filter:hover {
        filter: brightness(0) saturate(100%) invert(56%) sepia(77%)
            saturate(419%) hue-rotate(5deg) brightness(94%) contrast(92%)
            drop-shadow(0 6px 16px rgba(156, 122, 46, 0.35));
    }

    .linea-central {
        box-shadow: 0 0 15px rgba(156, 122, 46, 0.3);
    }
</style>

<script>
    import { gsap } from "gsap";
    import { ScrollTrigger } from "gsap/ScrollTrigger";

    gsap.registerPlugin(ScrollTrigger);

    const initItinerario = () => {
        gsap.set(".titulo-itinerario", { opacity: 0, y: -30 });
        gsap.set(".linea-central", { opacity: 0, scaleY: 0 });
        gsap.set(".corazon-item", { opacity: 0, scale: 0 });
        gsap.set(".evento-item", { opacity: 0 });
        gsap.set(".imagen-izq", { x: -60 });
        gsap.set(".texto-izq", { x: -60 });
        gsap.set(".imagen-der", { x: 60 });
        gsap.set(".texto-der", { x: 60 });

        ScrollTrigger.create({
            trigger: ".titulo-itinerario",
            start: "top 85%",
            once: true,
            onEnter: () => {
                gsap.to(".titulo-itinerario", {
                    opacity: 1,
                    y: 0,
                    duration: 1.2,
                    ease: "power3.out",
                });
            },
        });

        ScrollTrigger.create({
            trigger: "#eventos-container",
            start: "top 80%",
            end: "top 20%",
            onEnter: () => {
                const tl = gsap.timeline();
                tl.to(
                    ".linea-central",
                    {
                        opacity: 1,
                        scaleY: 1,
                        duration: 1.5,
                        ease: "power2.out",
                        transformOrigin: "top center",
                    },
                    0,
                )
                    .to(
                        ".corazon-item",
                        {
                            opacity: 1,
                            scale: 1,
                            duration: 0.8,
                            ease: "back.out(1.7)",
                        },
                        0,
                    )
                    .to(
                        ".evento-item",
                        { opacity: 1, duration: 1.0, ease: "power3.out" },
                        0,
                    )
                    .to(
                        ".imagen-izq, .texto-izq",
                        { x: 0, duration: 1.0, ease: "power3.out" },
                        0,
                    )
                    .to(
                        ".imagen-der, .texto-der",
                        { x: 0, duration: 1.0, ease: "power3.out" },
                        0,
                    );
            },
            onLeaveBack: () => {
                const tl = gsap.timeline();
                tl.to(
                    ".linea-central, .corazon-item, .evento-item",
                    { opacity: 0, duration: 0.4, ease: "power2.in" },
                    0,
                )
                    .to(
                        ".linea-central",
                        {
                            scaleY: 0,
                            duration: 0.4,
                            ease: "power2.in",
                            transformOrigin: "top center",
                        },
                        0,
                    )
                    .to(
                        ".corazon-item",
                        { scale: 0, duration: 0.4, ease: "power2.in" },
                        0,
                    )
                    .to(
                        ".imagen-izq, .texto-izq",
                        { x: -60, duration: 0.4, ease: "power2.in" },
                        0,
                    )
                    .to(
                        ".imagen-der, .texto-der",
                        { x: 60, duration: 0.4, ease: "power2.in" },
                        0,
                    );
            },
        });
    };

    document.addEventListener("DOMContentLoaded", initItinerario);
    document.addEventListener("astro:page-load", initItinerario);
</script>
