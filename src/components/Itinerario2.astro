---
// Itinerario.astro - Versión con colores de boda
---

<section class="px-4 relative overflow-hidden py-6">
    <div class="max-w-5xl mx-auto relative z-10">
        <div class="max-w-3xl mx-auto relative">
            <!-- Título -->
            <div class="text-center mb-6 titulo-itinerario opacity-0">
                <h2
                    class="font-charm text-2xl md:text-3xl lg:text-3xl text-[#C9A96E] font-bold mb-3"
                >
                    ITINERARIO
                </h2>
                <div class="flex items-center justify-center gap-3">
                    <div
                        class="w-16 h-[2px] bg-gradient-to-r from-transparent to-[#C9A96E]"
                    >
                    </div>
                    <div class="w-2 h-2 rounded-full bg-[#C9A96E]"></div>
                    <div
                        class="w-16 h-[2px] bg-gradient-to-l from-transparent to-[#C9A96E]"
                    >
                    </div>
                </div>
            </div>

            <div class="relative px-4 md:px-8">
                <!-- Línea central -->
                <div
                    class="absolute left-1/2 -translate-x-1/2 top-0 bottom-0 w-[3px] bg-gradient-to-b from-[#C9A96E] via-[#D4B87A] to-[#C9A96E] rounded-full shadow-sm linea-central opacity-0"
                >
